// firestore.rules
// Deploy these via: firebase deploy --only firestore:rules
// Or paste them in Firebase Console → Firestore → Rules tab.
//
// WHAT THESE RULES DO:
//   - Anyone can READ products (public marketplace)
//   - Only authenticated admin users can CREATE, UPDATE, DELETE products
//   - Writes go through our API routes which verify the auth token server-side
//     using Firebase Admin SDK — these rules are a second layer of protection.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Products collection — public reads, authenticated writes
    match /products/{productId} {
      // Anyone can read a single product or list products
      allow read: if true;

      // Only a signed-in user can write (create / update / delete)
      // In practice, writes go through /api/products which checks the token
      // server-side first — this is an extra safety net.
      allow create, update, delete: if request.auth != null;
    }

    // Block access to everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
